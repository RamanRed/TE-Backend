# Copy this file to `.env` and update values for your environment.

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
DEBUG=false
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# -----------------------------------------------------------------------------
# Neo4j
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_HOST=localhost
NEO4J_PORT=7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password
# Leave blank to use the default database configured by Neo4j.
NEO4J_DATABASE=

# -----------------------------------------------------------------------------
# Ollama / LLM
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT=900
OLLAMA_NUM_GPU=-1
OLLAMA_NUM_THREAD=0

# -----------------------------------------------------------------------------
# Root Cause / Ishikawa tuning
# -----------------------------------------------------------------------------
OLLAMA_TIMEOUT_FIVE_WHY=900
OLLAMA_TIMEOUT_ISHIKAWA=900

FIVE_WHY_MAX_CAUSES=4
FIVE_WHY_MIN_NUM_PREDICT=900
FIVE_WHY_MAX_NUM_PREDICT=1800
FIVE_WHY_TOKENS_PER_CAUSE=300

ISHIKAWA_NUM_PREDICT=3600
ISHIKAWA_MIN_RESULTS_PER_BONE=3
ISHIKAWA_FILL_EMPTY_CATEGORIES=true
ISHIKAWA_EMPTY_SUBCATEGORY=Needs Investigation
ISHIKAWA_EMPTY_EVIDENCE=No direct evidence supplied in model output; refine query or regenerate for deeper coverage.
ISHIKAWA_DEFAULT_SEVERITY=Medium
